{
  "info": {
    "name": "SUS Smart Assistant API",
    "description": "Collection para demonstração do SUS Smart Assistant — prontuário eletrônico unificado com assistente IA.\n\nFluxo de demo:\n1. Login\n2. Buscar paciente\n3. Ver prontuário\n4. Registrar atendimento\n5. Solicitar hipóteses IA\n6. Consultar resultado IA\n7. Métricas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "pacienteId", "value": "" },
    { "key": "solicitacaoId", "value": "" },
    { "key": "medicamentoId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Cadastros",
      "item": [
        {
          "name": "Cadastrar Unidade de Saúde",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"UBS Vila Madalena\",\n  \"cnes\": \"1234567\",\n  \"endereco\": \"Rua Harmonia, 100 - Vila Madalena, São Paulo - SP\",\n  \"telefone\": \"(11) 3030-1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/unidades-saude", "host": ["{{baseUrl}}"], "path": ["api", "v1", "unidades-saude"] }
          }
        },
        {
          "name": "Listar Unidades de Saúde",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/unidades-saude", "host": ["{{baseUrl}}"], "path": ["api", "v1", "unidades-saude"] }
          }
        },
        {
          "name": "Cadastrar Profissional de Saúde",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Dr. Carlos Souza\",\n  \"crm\": \"CRM/SP 123456\",\n  \"especialidade\": \"Clínica Geral\",\n  \"username\": \"medico2\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/profissionais", "host": ["{{baseUrl}}"], "path": ["api", "v1", "profissionais"] }
          }
        },
        {
          "name": "Cadastrar Paciente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('pacienteId', jsonData.id); }",
                  "pm.test('Paciente cadastrado', function () {",
                  "    pm.response.to.have.status(201);",
                  "    pm.expect(jsonData.id).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João da Silva\",\n  \"cpf\": \"71428793860\",\n  \"cns\": \"898001234560005\",\n  \"dataNascimento\": \"1985-03-22\",\n  \"sexo\": \"MASCULINO\",\n  \"telefone\": \"(11) 91234-5678\",\n  \"email\": \"joao.silva@email.com\",\n  \"endereco\": \"Rua das Flores, 42 - Jardim Paulista, São Paulo - SP\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/pacientes", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pacientes"] }
          }
        },
        {
          "name": "Registrar Alergia",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"substancia\": \"Penicilina\",\n  \"reacao\": \"Anafilaxia\",\n  \"gravidade\": \"CRITICA\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/pacientes/{{pacienteId}}/alergias", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pacientes", "{{pacienteId}}", "alergias"] }
          }
        },
        {
          "name": "Registrar Medicamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('medicamentoId', jsonData.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Losartana Potássica\",\n  \"dosagem\": \"50mg\",\n  \"frequencia\": \"1x ao dia\",\n  \"dataInicio\": \"2024-01-10\",\n  \"prescritoPor\": \"Dr. Carlos Souza - CRM/SP 123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/pacientes/{{pacienteId}}/medicamentos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pacientes", "{{pacienteId}}", "medicamentos"] }
          }
        },
        {
          "name": "Descontinuar Medicamento",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/pacientes/{{pacienteId}}/medicamentos/{{medicamentoId}}/descontinuar", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pacientes", "{{pacienteId}}", "medicamentos", "{{medicamentoId}}", "descontinuar"] }
          }
        },
        {
          "name": "Registrar Exame",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"Hemograma Completo\",\n  \"data\": \"2024-11-10\",\n  \"resultado\": \"Hemoglobina: 13.5 g/dL, Leucócitos: 8.200/mm³, Plaquetas: 220.000/mm³. Dentro dos limites normais.\",\n  \"laboratorio\": \"Laboratório Central SUS\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/prontuarios/{{pacienteId}}/exames", "host": ["{{baseUrl}}"], "path": ["api", "v1", "prontuarios", "{{pacienteId}}", "exames"] }
          }
        }
      ]
    },
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "Login como Médico",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);",
                  "pm.test('Login bem-sucedido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(jsonData.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"medico1\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Login como Paciente (Maria Silva)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);",
                  "pm.test('Login bem-sucedido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(jsonData.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"52998224725\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Login como Gestor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.token);",
                  "pm.test('Login bem-sucedido', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(jsonData.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"gestor1\",\n  \"senha\": \"senha123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "2. Buscar Paciente",
      "item": [
        {
          "name": "Buscar Maria Silva por CPF",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('pacienteId', jsonData.id); }",
                  "pm.test('Paciente encontrado', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/pacientes?cpf=52998224725",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "pacientes"],
              "query": [{ "key": "cpf", "value": "52998224725" }]
            }
          }
        }
      ]
    },
    {
      "name": "3. Prontuário",
      "item": [
        {
          "name": "Ver Prontuário Completo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/prontuarios/{{pacienteId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "prontuarios", "{{pacienteId}}"] }
          }
        },
        {
          "name": "Listar Alergias",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/pacientes/{{pacienteId}}/alergias", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pacientes", "{{pacienteId}}", "alergias"] }
          }
        },
        {
          "name": "Listar Medicamentos Ativos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/pacientes/{{pacienteId}}/medicamentos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pacientes", "{{pacienteId}}", "medicamentos"] }
          }
        },
        {
          "name": "Listar Atendimentos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/prontuarios/{{pacienteId}}/atendimentos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "prontuarios", "{{pacienteId}}", "atendimentos"] }
          }
        },
        {
          "name": "Listar Exames",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/prontuarios/{{pacienteId}}/exames", "host": ["{{baseUrl}}"], "path": ["api", "v1", "prontuarios", "{{pacienteId}}", "exames"] }
          }
        }
      ]
    },
    {
      "name": "4. Registrar Atendimento",
      "item": [
        {
          "name": "Novo Atendimento",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": \"2024-11-15\",\n  \"queixaPrincipal\": \"Dor de garganta e febre há 3 dias\",\n  \"anamnese\": \"Paciente refere odinofagia intensa com febre de 38.5°C. Nega dispneia.\",\n  \"diagnosticoCid\": \"J06\",\n  \"prescricoes\": \"Azitromicina 500mg 1x/dia por 3 dias\",\n  \"observacoes\": \"ATENÇÃO: Paciente alérgica a Penicilina (CRÍTICA). Reincidência de IVAS.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/prontuarios/{{pacienteId}}/atendimentos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "prontuarios", "{{pacienteId}}", "atendimentos"] }
          }
        }
      ]
    },
    {
      "name": "5. Assistente IA",
      "item": [
        {
          "name": "Solicitar Hipóteses Diagnósticas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) { pm.collectionVariables.set('solicitacaoId', jsonData.id); }",
                  "pm.test('Solicitação aceita (202)', function () {",
                  "    pm.response.to.have.status(202);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pacienteId\": \"{{pacienteId}}\",\n  \"sintomas\": [\"dor de garganta\", \"febre\", \"tosse produtiva\", \"congestão nasal\"]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/assistente/solicitacoes", "host": ["{{baseUrl}}"], "path": ["api", "v1", "assistente", "solicitacoes"] }
          }
        },
        {
          "name": "Consultar Resultado IA",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/assistente/solicitacoes/{{solicitacaoId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "assistente", "solicitacoes", "{{solicitacaoId}}"] }
          }
        }
      ]
    },
    {
      "name": "6. Métricas (Gestor)",
      "description": "Use o token do gestor1 para estas requisições",
      "item": [
        {
          "name": "Métricas de Atendimento",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/metricas/atendimentos?inicio=2023-01-01&fim=2024-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "metricas", "atendimentos"],
              "query": [
                { "key": "inicio", "value": "2023-01-01" },
                { "key": "fim", "value": "2024-12-31" }
              ]
            }
          }
        },
        {
          "name": "Diagnósticos Frequentes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/metricas/diagnosticos?inicio=2023-01-01&fim=2024-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "metricas", "diagnosticos"],
              "query": [
                { "key": "inicio", "value": "2023-01-01" },
                { "key": "fim", "value": "2024-12-31" }
              ]
            }
          }
        },
        {
          "name": "Métricas do Assistente IA",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/metricas/assistente?inicio=2023-01-01&fim=2024-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "metricas", "assistente"],
              "query": [
                { "key": "inicio", "value": "2023-01-01" },
                { "key": "fim", "value": "2024-12-31" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "7. Paciente - Meu Prontuário",
      "description": "Use o token do paciente1 para esta requisição",
      "item": [
        {
          "name": "Ver Meu Prontuário",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/meu-prontuario", "host": ["{{baseUrl}}"], "path": ["api", "v1", "meu-prontuario"] }
          }
        }
      ]
    }
  ]
}
